# ---------------------------------------------------------------------------
# Environment variables for local development and test (loaded by dotenv-rails).
#
# Copy this file to ".env" and fill in real values. ".env" is gitignored;
# this ".env.example" is the committed, secret-free template.
#
# Load order (later overrides earlier): .env.<env>.local, .env.local,
# .env.<env>, .env. Production should use real environment variables, Rails
# credentials, or Kamal secrets, not these files.
# ---------------------------------------------------------------------------

# Nostr relays the runtime reads/writes by default (comma-separated).
DEFAULT_RELAY_URLS=wss://relay.damus.io,wss://nos.lol

# The platform's own npub: recipient of the non-refundable open-request
# posting fee (brief section 10.2). Leave blank until decided (brief section 14).
PLATFORM_NPUB=

# Default Cashu mint URL for manual-mode escrow (brief section 10). Remember to
# disclose the custodial-mint caveat to users (brief section 15).
CASHU_MINT_URL=

R_OP_PRIVATE_KEY=
