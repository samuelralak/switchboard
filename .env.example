# ---------------------------------------------------------------------------
# Environment variables for local development and test (loaded by dotenv-rails).
#
# Copy this file to ".env" and fill in real values. ".env" is gitignored;
# this ".env.example" is the committed, secret-free template.
#
# Load order (later overrides earlier): .env.<env>.local, .env.local,
# .env.<env>, .env. Production should use real environment variables, Rails
# credentials, or Kamal secrets, not these files.
# ---------------------------------------------------------------------------

# Relay seeds are configured per-environment in config/relays.yml (not an env var).

# Absolute origin the NIP-98 sign-in is verified against. Dev defaults to http://localhost:3000;
# REQUIRED in production (a localhost default silently breaks auth).
CANONICAL_ORIGIN=

# Comma-separated Cashu mint URLs trusted for manual-mode escrow (brief section 10). Dev/test use a
# built-in local mint; production reads this list and an empty list disables ordering. Remember to
# disclose the custodial-mint caveat to users (brief section 15).
ESCROW_MINT_ALLOWLIST=

# The R_op operational key (64-hex private). Optional: without it the app boots and catalog ingest uses
# public relays; NIP-42 AUTH (AUTH-gated DM/inbox relays) activates once it is set. Generate with:
#   bin/rails runner 'puts Nostr::Keygen.new.generate_key_pair.private_key'
R_OP_PRIVATE_KEY=

# Tier-2 arbiter escrow (2-of-3): the platform's DEDICATED Cashu secp256k1 key (64-hex private). NOT R_op,
# NOT a Nostr key. The compressed public point is advertised to browsers so a consumer locks to it; the
# private key co-signs disputed locks at ruling time only (1-of-3, never a payee). Leave blank to disable
# Tier-2. See docs/tier2-arbiter-escrow.md.
ESCROW_TIER2_ARBITER_PRIVKEY=

# Platform operators: comma-separated 64-HEX Nostr pubkeys (NOT npubs) allowed onto the admin surface
# (/admin/disputes, Tier-2 dispute rulings). An allowlist, not a DB role: an operator signs in with their own
# Nostr key like any user; if their pubkey is listed here they get in, everyone else is sent home. Empty by
# default (the surface is closed). To act as admin, put your account's hex pubkey here and restart the server.
OPERATOR_PUBKEYS=
