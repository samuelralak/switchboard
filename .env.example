# Local dev/test env (dotenv-rails). Copy to ".env" (gitignored) and fill in.
# Production uses real env vars / Rails credentials / Kamal secrets, not these files.

# Absolute origin NIP-98 sign-in is verified against. Required in production.
CANONICAL_ORIGIN=

# Comma-separated Cashu mint URLs trusted for escrow. Empty disables ordering in production.
ESCROW_MINT_ALLOWLIST=

# R_op operational key (64-hex). Optional; enables NIP-42 AUTH relays when set.
R_OP_PRIVATE_KEY=

# Tier-2 arbiter Cashu key (64-hex, dedicated). Blank disables Tier-2. See docs/tier2-arbiter-escrow.md.
ESCROW_TIER2_ARBITER_PRIVKEY=

# Comma-separated 64-hex pubkeys allowed onto the admin surface. Empty = closed.
OPERATOR_PUBKEYS=

# Platform attestation (docs/attestation-architecture.md). Catalog policy: off | badge | exclude (default badge).
ATTESTATION_POLICY=

# Issuing key (64-hex). Blank reuses R_OP_PRIVATE_KEY.
ATTESTATION_PRIVATE_KEY=

# Verify another issuer's labels without a signing key: their 64-hex pubkey.
ATTESTATION_PUBKEY=

# Paid gate: true requires a listing fee before attesting (default false).
ATTESTATION_REQUIRE_FEE=
