<% content_for(:title, "Settings") %>

<%= render Settings::Shell::ShellComponent.new(active: :relays) do %>
  <div class="mb-6">
    <h2 class="text-base font-semibold text-ink">Relays</h2>
    <p class="mt-1 text-sm text-ink-muted">Where your messages and listings are published and read.</p>
  </div>

  <ul role="list" class="divide-y divide-border border-y border-border">
    <% display_relays.each do |relay| %>
      <li class="flex items-center gap-3 py-3">
        <span class="size-1.5 shrink-0 rounded-full <%= relay_status_class(relay[:status]) %>" title="<%= relay[:status] %>"></span>
        <span class="truncate font-mono text-xs text-ink-secondary"><%= relay[:host] %></span>
        <span class="ml-auto font-mono text-[0.625rem] uppercase tracking-widest text-ink-faint"><%= relay_role(relay) %></span>
        <button type="button" class="-m-1.5 p-1.5 text-ink-faint transition-colors hover:text-ink" aria-label="Remove <%= relay[:host] %>">
          <i class="hgi-stroke hgi-cancel-01 text-sm" aria-hidden="true"></i>
        </button>
      </li>
    <% end %>
  </ul>

  <%# Add a relay (inline; no modal). %>
  <div class="mt-4 flex gap-2">
    <input type="url" inputmode="url" autocomplete="off" placeholder="wss://relay.example.com" aria-label="Relay URL"
           class="block w-full rounded-lg border border-border bg-inset px-3.5 py-2.5 font-mono text-xs text-ink placeholder:text-ink-faint transition-colors hover:border-border-strong focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">
    <%= render Shared::Button::ButtonComponent.new(size: :sm, icon: "add-01") do %>Add<% end %>
  </div>

  <p class="mt-3 text-xs text-ink-faint">Editing relays publishes a NIP-65 list signed with your key &mdash; coming soon.</p>
<% end %>
