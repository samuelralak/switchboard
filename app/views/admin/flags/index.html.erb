<% content_for :title, "Flagged identities" %>

<%= render "admin/nav" %>

<div class="mx-auto max-w-3xl">
  <div class="mb-5">
    <h1 class="font-display text-lg font-semibold tracking-tight text-ink">Flagged identities</h1>
    <p class="mt-0.5 text-sm text-ink-muted">Operator takedown. A flagged pubkey's listings, open requests, and profile page are hidden from the public surfaces. Reversible, and it never moves funds.</p>
  </div>

  <%= form_with url: admin_flags_path, method: :post, class: "mb-6 flex flex-col gap-2 sm:flex-row" do %>
    <input type="text" name="pubkey" required placeholder="npub1… or 64-hex pubkey"
           class="w-full rounded-md border border-border bg-surface px-3 py-2 font-mono text-sm text-ink placeholder:text-ink-faint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright">
    <%= render Shared::Button::ButtonComponent.new(variant: :primary, type: "submit", icon: "shield-01",
          data: { turbo_confirm: "Flag this identity? Its public content will be hidden." }) do %>Flag<% end %>
  <% end %>

  <% if @flagged.any? %>
    <div class="flex flex-col gap-2">
      <% @flagged.each do |user| %>
        <div class="flex items-center justify-between gap-4 rounded-lg border border-border bg-surface p-3">
          <div class="min-w-0">
            <p class="truncate font-mono text-xs text-ink-secondary" title="<%= user.npub %>"><%= user.npub %></p>
            <% if user.named? %>
              <p class="mt-0.5 truncate text-sm text-ink"><%= user.display %></p>
            <% end %>
          </div>
          <%= button_to "Unflag", admin_flag_path(user.pubkey), method: :delete,
                class: "shrink-0 rounded-md border border-border px-3 py-1.5 text-sm font-medium text-ink hover:bg-canvas" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="rounded-lg border border-dashed border-border p-6 text-center text-sm text-ink-muted">No flagged identities.</p>
  <% end %>
</div>
