<% content_for :title, "Platform settings" %>

<%= render "admin/nav" %>

<div class="mx-auto max-w-3xl">
  <div class="mb-5">
    <h1 class="font-display text-lg font-semibold tracking-tight text-ink">Platform settings</h1>
    <p class="mt-0.5 text-sm text-ink-muted">Operator controls for the hosted platform.</p>
  </div>

  <%= form_with url: admin_settings_path, method: :patch do %>
    <fieldset class="space-y-2">
      <legend class="mb-1.5 text-xs font-medium uppercase tracking-wider text-ink-faint">Default catalog view</legend>
      <p class="mb-2.5 text-xs leading-relaxed text-ink-muted">The view new visitors start on. Each visitor can switch it themselves from the catalog filter, and signed-in members can save their own default.</p>

      <label class="flex cursor-pointer gap-2.5 rounded-lg border border-border p-3 has-[:checked]:border-copper-dim has-[:checked]:bg-copper/5">
        <input type="radio" name="attestation_policy" value="exclude" <%= "checked" if @policy == "exclude" %> class="mt-0.5 accent-copper">
        <span class="text-sm">
          <span class="flex items-center gap-2">
            <span class="font-medium text-ink">Verified first</span>
            <span class="rounded-full bg-copper/10 px-2 py-0.5 text-xs font-medium uppercase tracking-wider text-copper">Default</span>
          </span>
          <span class="mt-0.5 block text-xs leading-relaxed text-ink-muted">Visitors start seeing only platform-attested listings and requests; they can switch to all to discover the rest. Leads with what you have vouched for.</span>
        </span>
      </label>

      <label class="flex cursor-pointer gap-2.5 rounded-lg border border-border p-3 has-[:checked]:border-copper-dim has-[:checked]:bg-copper/5">
        <input type="radio" name="attestation_policy" value="badge" <%= "checked" if @policy == "badge" %> class="mt-0.5 accent-copper">
        <span class="text-sm">
          <span class="font-medium text-ink">Show all</span>
          <span class="mt-0.5 block text-xs leading-relaxed text-ink-muted">Visitors start seeing everything; attested items carry a trust badge and they can filter to verified only.</span>
          <span class="mt-1.5 inline-block"><%= render Shared::AttestationBadge::AttestationBadgeComponent.new(attested: true) %></span>
        </span>
      </label>

      <label class="flex cursor-pointer gap-2.5 rounded-lg border border-border p-3 has-[:checked]:border-copper-dim has-[:checked]:bg-copper/5">
        <input type="radio" name="attestation_policy" value="off" <%= "checked" if @policy == "off" %> class="mt-0.5 accent-copper">
        <span class="text-sm">
          <span class="font-medium text-ink">Off</span>
          <span class="mt-0.5 block text-xs leading-relaxed text-ink-muted">No badges, no verification filter. The catalog is fully open and attestation is invisible.</span>
        </span>
      </label>
    </fieldset>

    <p class="mt-3 text-xs leading-relaxed text-ink-muted">Verification only takes effect once an issuer key is configured (<span class="font-mono">ATTESTATION_PRIVATE_KEY</span>, or <span class="font-mono">R_OP_PRIVATE_KEY</span> as the fallback). Without one, every listing is shown and the filter is hidden.</p>

    <div class="mt-5">
      <%= render Shared::Button::ButtonComponent.new(variant: :primary, type: "submit", icon: "shield-01",
            data: { turbo_confirm: "Change the default catalog view? This is what new visitors see first." }) do %>Save default<% end %>
    </div>
  <% end %>
</div>
