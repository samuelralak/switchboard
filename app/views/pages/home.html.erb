<% content_for :title, "Catalog" %>

<%= turbo_stream_from @catalog.stream %>
<%= turbo_stream_from @board.stream %>

<%# Pre-hide unattested cards (CSS) when verified, so there's no flash before the controller connects. %>
<section data-controller="catalog" data-catalog-mode-value="all"
         data-catalog-attestation-value="<%= @catalog_view %>"
         <% if signed_in? %>data-catalog-attestation-persist-url-value="<%= settings_browsing_path %>"<% end %>
         class="<%= "catalog-verified-cloak" if @catalog_view == "verified" %>"
         data-action="keydown@window->catalog#focusSearch">
  <%# Hero + intent search %>
  <div class="mx-auto mb-7 max-w-4xl text-center">
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-copper">ask for anything</p>
    <h1 class="mb-6 text-hero font-display font-semibold leading-tight tracking-tight text-ink">What do you need done?</h1>

    <%# v0/Lovable-style intent composer: one inset surface, a plain-language %>
    <%# description, and two ways out: search the market, or post the demand. %>
    <%= simple_form_for :search, url: root_path, method: :get,
          html: { class: "mx-auto max-w-4xl text-left", data: { action: "submit->catalog#route" } } do |f| %>
      <div class="rounded-xl border border-border-strong bg-inset transition has-[textarea:focus]:border-copper-dim has-[textarea:focus]:ring-2 has-[textarea:focus]:ring-copper-bright/60 has-[textarea:focus]:ring-offset-2 has-[textarea:focus]:ring-offset-canvas">
        <div class="relative">
          <%= f.input_field :q, as: :text, name: "q", value: @catalog.query, autocomplete: "off", rows: 3,
                placeholder: "Describe what you need in plain language to search services and open requests on Nostr…",
                "aria-label": "Describe what you need",
                data: { "catalog-target": "query", action: "input->catalog#filter keydown->catalog#submitShortcut" },
                class: "block min-h-24 max-h-60 w-full resize-none bg-transparent px-4 pb-2 pr-12 pt-4 font-sans text-sm leading-relaxed text-ink placeholder:text-ink-faint focus:outline-none" %>
          <button type="button" data-catalog-target="clear" data-action="catalog#clear" hidden aria-label="Clear description"
                  class="absolute right-2.5 top-2.5 flex size-7 items-center justify-center rounded-md text-ink-faint transition-colors hover:bg-surface hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">
            <%= render Shared::Icon::IconComponent.new(name: "cancel-01", size: :sm) %>
          </button>
        </div>
        <div class="flex items-center justify-between gap-3 px-4 pb-3 pt-1">
          <%= render Shared::Button::ButtonComponent.new(tag: :a, href: new_request_path, variant: :ghost, size: :sm, icon: "add-01") do %>Post a request<% end %>
          <%= render Shared::Button::ButtonComponent.new(variant: :primary, size: :sm, type: "submit", icon: "sent") do %>Route it<% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# The defining guarantee %>
  <div class="mx-auto mb-12 flex max-w-4xl items-start gap-3 rounded-xl border border-copper-dim/40 bg-copper/5 px-4 py-3">
    <%= render Shared::Icon::IconComponent.new(name: "shield-01", color: "text-copper", extra: "mt-0.5 shrink-0") %>
    <p class="min-w-0 text-sm leading-relaxed text-ink-secondary">
      <span class="font-medium text-ink">Every transaction is escrowed.</span>
      Funds lock in escrow and release only on delivery, with an automatic refund if the work never
      arrives. The escrow protects you on every job, key-locked to you, never the provider. A Cashu
      mint holds the backing sats while locked.
    </p>
  </div>

  <%# Marketplace: a lens switch (services = supply, open requests = demand) over one search. %>
  <div class="mx-auto max-w-4xl">
    <div data-catalog-target="results" class="mb-5 scroll-mt-24">
      <%# Mobile: a select swaps the lens. %>
      <div class="relative sm:hidden">
        <select aria-label="Browse the marketplace" data-catalog-target="viewSelect" data-action="catalog#setViewFromSelect"
                class="w-full appearance-none rounded-lg border border-border bg-surface py-2 pl-3 pr-9 text-sm font-medium text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright">
          <option value="service">Services</option>
          <option value="request">Open requests</option>
        </select>
        <%# Caret positioning lives on the wrapper span, not the icon: the icon-font sets position on the <i>
            itself, which cancels an `absolute` placed directly on it (it then falls into normal flow). %>
        <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
          <i class="hgi-stroke hgi-arrow-down-01 text-xs text-ink-faint" aria-hidden="true"></i>
        </span>
      </div>

      <%# Desktop: underlined tabs (left) + sort/mode (right), sharing one baseline border. items-end +
          the nav's -mb-px let the active tab's border-b-2 sit ON the row border (no gap). %>
      <div class="mt-3 flex items-end justify-between gap-4 sm:mt-0 sm:border-b sm:border-border">
        <nav role="tablist" aria-label="Browse the marketplace" class="hidden -mb-px sm:flex sm:gap-8">
          <% [["service", "Services", @catalog.size], ["request", "Open requests", @board.size]].each do |view, label, count| %>
            <% active = view == "service" %>
            <button type="button" role="tab" data-catalog-target="tab" data-view="<%= view %>" data-action="catalog#setView"
                    aria-selected="<%= active %>"
                    class="flex items-center whitespace-nowrap rounded-sm border-b-2 px-1 pb-3 text-sm font-medium transition-colors hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright <%= active ? "border-copper text-ink" : "border-transparent text-ink-muted" %>">
              <%= label %>
              <span data-role="count" class="ml-2 rounded-full px-2 py-0.5 font-mono text-xs <%= active ? "bg-copper/15 text-copper" : "bg-inset text-ink-secondary" %>"><%= count %></span>
            </button>
          <% end %>
        </nav>

        <div class="flex flex-wrap items-center justify-end gap-2 sm:ml-auto sm:flex-nowrap sm:pb-2">
          <%# Per-viewer attestation filter (All vs platform-Verified). Shown only when attestation is on; the
              operator policy sets the default, each viewer overrides it (remembered locally + per account). %>
          <% if @attestation_filter %>
            <div role="group" aria-label="Filter by platform verification" class="inline-flex h-10 items-center gap-0.5 rounded-lg border border-border bg-surface p-0.5 sm:h-9">
              <button type="button" data-catalog-target="attestationButton" data-attestation="all" data-action="catalog#setAttestation" aria-pressed="<%= @catalog_view == "all" %>"
                      class="h-8 rounded-md px-3.5 text-sm font-medium transition-colors hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas sm:h-7 <%= @catalog_view == "all" ? "bg-surface-2 text-ink" : "text-ink-muted" %>">All</button>
              <button type="button" data-catalog-target="attestationButton" data-attestation="verified" data-action="catalog#setAttestation" aria-pressed="<%= @catalog_view == "verified" %>"
                      class="flex h-8 items-center gap-1 rounded-md px-3 text-sm font-medium transition-colors hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas sm:h-7 <%= @catalog_view == "verified" ? "bg-surface-2 text-ink" : "text-ink-muted" %>">
                <i class="hgi-stroke hgi-checkmark-circle-02 text-xs <%= @catalog_view == "verified" ? "text-copper" : "text-ink-muted" %>" aria-hidden="true"></i>Verified
              </button>
            </div>
          <% end %>
          <el-dropdown class="relative">
            <button type="button" class="inline-flex h-10 items-center gap-1.5 rounded-lg border border-border bg-surface px-3 text-sm font-medium text-ink-secondary transition-colors hover:border-border-strong hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas sm:h-9">
              Sort: <span data-catalog-target="sortLabel" class="text-ink">Newest</span>
              <i class="hgi-stroke hgi-arrow-down-01 text-xs text-ink-faint" aria-hidden="true"></i>
            </button>
            <el-menu anchor="bottom end" popover class="w-44 origin-top-right rounded-xl border border-border bg-surface-2 py-1.5 shadow-panel transition transition-discrete [--anchor-gap:--spacing(2)] data-closed:scale-95 data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
              <% [["newest", "Newest"], ["price-asc", "Lowest price"], ["price-desc", "Highest price"]].each do |value, label| %>
                <button type="button" data-action="catalog#setSort" data-sort="<%= value %>"
                        class="block w-full px-3 py-1.5 text-left text-sm text-ink-secondary transition-colors hover:bg-surface hover:text-ink"><%= label %></button>
              <% end %>
            </el-menu>
          </el-dropdown>
          <%# Fulfillment mode applies to services only; hidden on the Open-requests lens. %>
          <div data-catalog-target="modeFilter" class="inline-flex h-10 items-center gap-0.5 rounded-lg border border-border bg-surface p-0.5 sm:h-9">
            <% [["all", "All"], ["automated", "Automated"], ["manual", "Human"]].each do |value, label| %>
              <button type="button" data-catalog-target="modeButton" data-mode="<%= value %>" data-action="catalog#setMode" aria-pressed="<%= value == "all" %>"
                      class="h-8 rounded-md px-3.5 text-sm font-medium transition-colors hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas sm:h-7 <%= value == "all" ? "bg-surface-2 text-ink" : "text-ink-muted" %>"><%= label %></button>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# Services (supply) and open requests (demand): both rendered; the active lens shows one type. Each %>
    <%# list keeps its own stream target so live listings/requests prepend into the right lens. %>
    <div id="<%= @catalog.grid_target %>" data-catalog-target="list" class="flex flex-col gap-3">
      <%= render partial: @catalog.partial, collection: @catalog.listings, as: :listing %>
    </div>
    <div id="<%= @board.grid_target %>" data-catalog-target="list" class="flex flex-col gap-3">
      <%= render partial: @board.partial, collection: @board.requests, as: :request %>
    </div>

    <%# Per-lens empty state (the controller shows the active lens's block when it has nothing to show). %>
    <div data-catalog-target="empty" data-view="service"<%= " hidden" unless @catalog.size.zero? %> class="mt-2">
      <%= render Shared::EmptyState::EmptyStateComponent.new(
            title: "No services here", body: "Nothing matches, or none are published yet. Try a different search.", icon: "search-01") %>
    </div>
    <div data-catalog-target="empty" data-view="request" hidden class="mt-2">
      <%= render Shared::EmptyState::EmptyStateComponent.new(
            title: "No open requests here", body: "Nothing matches, or none posted yet. Post one the catalog doesn't cover.", icon: "sent") %>
    </div>

    <%# Filter-aware empty state: shown when the Verified filter hides everything in the active lens but the All
        view has more. Distinguishes "nothing here" from "you are only viewing verified" and offers a way out. %>
    <% if @attestation_filter %>
      <div data-catalog-target="verifiedEmpty" data-view="service" hidden class="mt-2">
        <%= render Shared::EmptyState::EmptyStateComponent.new(
              title: "No verified services yet", body: "You're viewing platform-verified listings only. Switch to All to see everything on the marketplace.", icon: "checkmark-circle-02") do %>
          <%= render Shared::Button::ButtonComponent.new(variant: :primary, size: :sm, data: { action: "catalog#setAttestation", attestation: "all" }) do %>Show all listings<% end %>
        <% end %>
      </div>
      <div data-catalog-target="verifiedEmpty" data-view="request" hidden class="mt-2">
        <%= render Shared::EmptyState::EmptyStateComponent.new(
              title: "No verified requests yet", body: "You're viewing platform-verified requests only. Switch to All to see everything on the board.", icon: "checkmark-circle-02") do %>
          <%= render Shared::Button::ButtonComponent.new(variant: :primary, size: :sm, data: { action: "catalog#setAttestation", attestation: "all" }) do %>Show all requests<% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Detail drawers (one per card), opened via commandfor. A live broadcast appends a newly-arrived
      card's drawer here so its prepended card is not a dead button. One container per type. %>
  <div id="<%= Catalog::Ui::State::DRAWER_TARGET %>">
    <% @catalog.listings.each do |listing| %>
      <%= render "catalog/drawer", listing: listing %>
    <% end %>
  </div>
  <div id="<%= Requests::Ui::State::DRAWER_TARGET %>">
    <% @board.requests.each do |request| %>
      <%= render "requests/drawer", request: request %>
    <% end %>
  </div>
</section>
