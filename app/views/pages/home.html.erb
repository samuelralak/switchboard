<% content_for :title, "Catalog" %>

<%= turbo_stream_from @catalog.stream %>

<section data-controller="catalog" data-catalog-mode-value="all"
         data-action="keydown@window->catalog#focusSearch">
  <%# Hero + intent search %>
  <div class="mb-7 text-center">
    <p class="mb-3 font-mono text-xs uppercase tracking-widest text-copper">ask for anything</p>
    <h1 class="mb-6 text-hero font-display font-semibold leading-tight tracking-tight text-ink">What do you need done?</h1>

    <%# v0/Lovable-style intent composer: one inset surface, a plain-language %>
    <%# description, and two ways out: filter the catalog, or post the demand. %>
    <%= simple_form_for :search, url: root_path, method: :get,
          html: { class: "mx-auto max-w-3xl text-left", data: { action: "submit->catalog#route" } } do |f| %>
      <div class="rounded-xl border border-border-strong bg-inset transition has-[textarea:focus]:border-copper-dim has-[textarea:focus]:ring-2 has-[textarea:focus]:ring-copper-bright/60 has-[textarea:focus]:ring-offset-2 has-[textarea:focus]:ring-offset-canvas">
        <div class="relative">
          <%= f.input_field :q, as: :text, name: "q", value: @catalog.query, autocomplete: "off", rows: 3,
                placeholder: "Describe it in plain language to filter the catalog of services published to Nostr…",
                "aria-label": "Describe what you need",
                data: { "catalog-target": "query", action: "input->catalog#filter keydown->catalog#submitShortcut" },
                class: "block min-h-24 max-h-60 w-full resize-none bg-transparent px-4 pb-2 pr-12 pt-4 font-sans text-sm leading-relaxed text-ink placeholder:text-ink-faint focus:outline-none" %>
          <button type="button" data-catalog-target="clear" data-action="catalog#clear" hidden aria-label="Clear description"
                  class="absolute right-2.5 top-2.5 flex size-7 items-center justify-center rounded-md text-ink-faint transition-colors hover:bg-surface hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">
            <%= render Shared::Icon::IconComponent.new(name: "cancel-01", size: :sm) %>
          </button>
        </div>
        <div class="flex items-center justify-between gap-3 px-4 pb-3 pt-1">
          <%= render Shared::Button::ButtonComponent.new(tag: :a, href: "#", variant: :ghost, size: :sm, icon: "add-01") do %>Post a request<% end %>
          <%= render Shared::Button::ButtonComponent.new(variant: :primary, size: :sm, type: "submit", icon: "sent") do %>Route it<% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# The defining guarantee %>
  <div class="mx-auto mb-24 flex max-w-3xl items-start gap-3 rounded-xl border border-copper-dim/40 bg-copper/5 px-4 py-3">
    <%= render Shared::Icon::IconComponent.new(name: "shield-01", color: "text-copper", extra: "mt-0.5 shrink-0") %>
    <p class="text-sm leading-relaxed text-ink-secondary">
      <span class="font-medium text-ink">Every transaction is escrowed.</span>
      Funds lock at request and release only on delivery, with an automatic refund if the work never
      arrives. The platform guarantees it on every job, not the provider.
    </p>
  </div>

  <%# Catalog header + mode filter %>
  <div data-catalog-target="results" class="mb-5 flex scroll-mt-24 items-center justify-between gap-3">
    <h2 class="font-display text-lg font-semibold tracking-tight text-ink">
      Catalog <span class="ml-1 font-mono text-sm font-normal text-ink-faint" data-catalog-target="count"><%= @catalog.size %></span>
    </h2>
    <div class="inline-flex items-center gap-0.5 rounded-lg border border-border bg-surface p-0.5">
      <% [["all", "All"], ["automated", "Automated"], ["manual", "Human"]].each do |value, label| %>
        <button type="button" data-catalog-target="modeButton" data-mode="<%= value %>" data-action="catalog#setMode"
                class="h-8 rounded-md px-3.5 text-sm font-medium transition-colors hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas <%= value == "all" ? "bg-surface-2 text-ink" : "text-ink-muted" %>"><%= label %></button>
      <% end %>
    </div>
  </div>

  <%# Live, filterable grid %>
  <div id="<%= @catalog.grid_target %>" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <%= render partial: @catalog.partial, collection: @catalog.listings, as: :listing %>
  </div>

  <%# Shown by the catalog controller when a search/filter matches nothing %>
  <div data-catalog-target="empty"<%= " hidden" unless @catalog.no_matches? %> class="mt-2">
    <%= render Shared::EmptyState::EmptyStateComponent.new(
          title: "No services match", body: "Try a different search, or switch the filter back to All.", icon: "search-01") %>
  </div>

  <%# Nothing ingested yet %>
  <% if @catalog.never_ingested? %>
    <%= render Shared::EmptyState::EmptyStateComponent.new(
          title: "The catalog is empty", body: "Run the relay client (bin/rails relay:boot) to ingest NIP-99 listings from relays.", icon: "store-01") %>
  <% end %>

  <%# Service-detail drawers (one per listing), opened by the card buttons via commandfor. A live
      broadcast appends a newly-ingested listing's drawer here so its prepended card is not a dead button. %>
  <div id="<%= Catalog::Ui::State::DRAWER_TARGET %>">
    <% @catalog.listings.each do |listing| %>
      <%= render "catalog/drawer", listing: listing %>
    <% end %>
  </div>
</section>
