<div class="mx-auto max-w-2xl px-4 py-10"
     data-controller="dm-client"
     data-dm-client-pubkey-value="<%= @pubkey %>"
     data-dm-client-relays-value="<%= @dm_relays.to_json %>"
     data-dm-client-inbox-url-value="<%= inbox_path %>">
  <header class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900">Direct messages</h1>
    <p class="mt-1 text-sm text-gray-500">
      End-to-end encrypted (NIP-17). Messages are sealed and unsealed in this browser; the server never sees them.
    </p>
    <p class="mt-2 text-xs text-gray-400">
      You: <span class="font-mono break-all"><%= @pubkey %></span>
    </p>
  </header>

  <ul data-dm-client-target="thread"
      class="mb-6 min-h-24 space-y-2 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-gray-800"></ul>

  <form data-dm-client-target="form" data-action="dm-client#send" class="space-y-3">
    <input data-dm-client-target="peer" type="text" inputmode="latin" autocomplete="off"
           placeholder="recipient pubkey (64-hex)"
           class="block w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-sm" />
    <textarea data-dm-client-target="body" rows="3" placeholder="Write a message…"
              class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"></textarea>
    <div class="flex items-center justify-between gap-4">
      <p data-dm-client-target="status" role="status" aria-live="polite" class="text-xs text-gray-500"></p>
      <button type="submit"
              class="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700">Send</button>
    </div>
  </form>
</div>
