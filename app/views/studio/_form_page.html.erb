<%# Studio authoring page (new + edit). The shared shell lives in Shared::AuthoringPage; this supplies %>
<%# studio's Stimulus wiring, the service form, the publish actions, the receipt, and the buyer preview. %>
<%# locals: draft, pubkey, publish_relays, d_tag (nil = new, mint a fresh id), heading, subtitle, btc_usd %>
<%= render Shared::AuthoringPage::AuthoringPageComponent.new(
      stimulus: "studio",
      values: {
        "pubkey" => pubkey, "marker" => Catalog::Listing.marker,
        "capability-namespace" => Catalog::Listing::CAPABILITY_NAMESPACE,
        "origin" => Rails.application.config.x.canonical_origin,
        "relays" => publish_relays.to_json, "btc-usd" => btc_usd || 0
      },
      sections: Studio::ServiceForm::ServiceFormComponent::SECTIONS,
      heading: heading, subtitle: subtitle) do |page| %>
  <% page.with_form do %>
    <%= render Studio::ServiceForm::ServiceFormComponent.new(listing: draft, pubkey: pubkey, d_tag: d_tag) %>
  <% end %>

  <% page.with_actions do %>
    <button type="button" command="show-modal" commandfor="studio-preview-drawer" data-action="studio#previewAsBuyer"
            class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-lg border border-border px-4 text-sm font-medium text-ink-secondary transition-colors hover:border-border-strong hover:bg-ink/5 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">
      <%= render Shared::Icon::IconComponent.new(name: "view", size: :sm) %>
      Preview as buyer
    </button>
    <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, icon: "rocket-01",
          data: { action: "studio#publish", studio_target: "publish" }) do %>Sign &amp; publish listing<% end %>
    <p class="px-0.5 text-xs leading-relaxed text-ink-faint">
      Signs a conforming <span class="font-mono text-ink-muted">NIP-99</span> listing and a
      <span class="font-mono text-ink-muted">NIP-89</span> announcement with your key. Switchboard never holds it.
    </p>
  <% end %>

  <% page.with_receipt do %>
    <%= render "studio/receipt" %>
  <% end %>

  <% page.with_preview do %>
    <%= render Shared::Drawer::DrawerComponent.new(title: "Buyer preview", id: "studio-preview-drawer") do %>
      <%= render "studio/preview", listing: draft %>
    <% end %>
  <% end %>
<% end %>
