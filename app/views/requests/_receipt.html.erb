<%# Shown by request_form_controller after a successful post; replaces the form. %>
<div data-request-form-target="receipt" hidden class="rounded-2xl border border-lamp-settled/40 bg-lamp-settled/5 p-6">
  <div class="flex items-center gap-2.5">
    <%= render Shared::Icon::IconComponent.new(name: "checkmark-circle-02", size: :lg, color: "text-lamp-settled") %>
    <h3 class="font-display text-lg font-semibold tracking-tight text-ink">Request posted</h3>
  </div>

  <p data-request-form-target="receiptDetail" class="mt-2 text-sm leading-relaxed text-ink-secondary"></p>

  <div class="mt-3">
    <p class="text-xs font-medium uppercase tracking-wider text-ink-muted">coordinate</p>
    <p data-request-form-target="receiptCoordinate" class="mt-1 break-all font-mono text-xs text-ink-faint"></p>
  </div>

  <div class="mt-5 flex flex-wrap gap-2.5">
    <%= render Shared::Button::ButtonComponent.new(tag: :a, href: requests_path, variant: :primary, icon: "package") do %>View my requests<% end %>
    <%= render Shared::Button::ButtonComponent.new(variant: :ghost, icon: "add-01", data: { action: "request-form#publishAnother" }) do %>Post another<% end %>
  </div>
</div>
