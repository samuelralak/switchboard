<% content_for :title, "My requests" %>

<%# The consumer's ledger: orders you've placed (catalog orders + claimed requests) up top, then the
    requests you've posted that are still awaiting a claim. %>
<div class="mx-auto max-w-4xl">
  <header class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="mb-2.5 font-mono text-xs uppercase tracking-widest text-copper">your activity</p>
      <h1 class="font-display text-2xl font-semibold tracking-tight text-ink sm:text-3xl">My requests</h1>
      <p class="mt-2 max-w-xl leading-relaxed text-ink-muted">
        Orders you've placed and requests you've posted, tracked here.
      </p>
    </div>
    <%= render Shared::Button::ButtonComponent.new(tag: :a, href: new_request_path, variant: :primary, icon: "add-01", extra: "shrink-0") do %>Post a request<% end %>
  </header>

  <% if @orders.empty? && @board.size.zero? %>
    <%= render Shared::EmptyState::EmptyStateComponent.new(
          title: "Nothing here yet", body: "Order a service from the catalog, or post a request it doesn't cover.", icon: "package") do %>
      <%= render Shared::Button::ButtonComponent.new(tag: :a, href: new_request_path, variant: :primary, icon: "add-01") do %>Post a request<% end %>
    <% end %>
  <% else %>
    <%# orders you've placed, active then settled %>
    <% { "active" => @orders.select(&:active?), "settled & terminal" => @orders.reject(&:active?) }.each do |label, rows| %>
      <% next if rows.empty? %>
      <div class="mt-6 mb-2.5 first:mt-0">
        <p class="text-xs font-medium uppercase tracking-wider text-ink-muted"><%= label %></p>
      </div>
      <div class="flex flex-col gap-3">
        <% rows.each do |row| %>
          <%= render Orders::LedgerRow::LedgerRowComponent.new(row:) %>
        <% end %>
      </div>
    <% end %>

    <%# requests you've posted, still awaiting a claim %>
    <% if @board.size.positive? %>
      <section data-controller="catalog" data-catalog-view-value="request" class="mt-8">
        <div class="mb-2.5">
          <p class="text-xs font-medium uppercase tracking-wider text-ink-muted">posted, awaiting a claim</p>
        </div>
        <div id="<%= @board.grid_target %>" data-catalog-target="list" class="flex flex-col gap-3">
          <%= render partial: @board.partial, collection: @board.requests, as: :request %>
        </div>
      </section>
    <% end %>
  <% end %>

  <%# Request-detail drawers (one per posted request), opened by the card buttons via commandfor. %>
  <div id="<%= Requests::Ui::State::DRAWER_TARGET %>">
    <% @board.requests.each do |request| %>
      <%= render "requests/drawer", request: request %>
    <% end %>
  </div>
</div>

<%# the order drawer, open when ?order_id points at one of your orders %>
<% if @open_order %>
  <%= render "orders/drawer", order_id: @open_order.id, title: @open_order.title, close_path: requests_path %>
<% end %>
