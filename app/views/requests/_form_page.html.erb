<%# Open-request authoring page. The shared shell lives in Shared::AuthoringPage; this supplies the %>
<%# request's Stimulus wiring, the request form, the post actions, the receipt, and the request preview. %>
<%# locals: draft, pubkey, publish_relays, d_tag (nil = new, mint a fresh id), heading, subtitle, btc_usd %>
<%= render Shared::AuthoringPage::AuthoringPageComponent.new(
      stimulus: "request-form",
      values: {
        "pubkey" => pubkey, "marker" => Requests::OpenRequest.marker,
        "capability-namespace" => Catalog::Listing::CAPABILITY_NAMESPACE,
        "relays" => publish_relays.to_json, "btc-usd" => btc_usd || 0
      },
      sections: Requests::RequestForm::RequestFormComponent::SECTIONS,
      heading: heading, subtitle: subtitle) do |page| %>
  <% page.with_form do %>
    <%= render Requests::RequestForm::RequestFormComponent.new(request: draft, pubkey: pubkey, d_tag: d_tag) %>
  <% end %>

  <% page.with_actions do %>
    <button type="button" command="show-modal" commandfor="request-preview-drawer" data-action="request-form#previewAsBuyer"
            class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-lg border border-border px-4 text-sm font-medium text-ink-secondary transition-colors hover:border-border-strong hover:bg-ink/5 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas">
      <%= render Shared::Icon::IconComponent.new(name: "view", size: :sm) %>
      Preview request
    </button>
    <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, icon: "sent",
          data: { action: "request-form#publish", request_form_target: "publish" }) do %>Sign &amp; post request<% end %>
    <p class="px-0.5 text-xs leading-relaxed text-ink-faint">
      Signs a conforming <span class="font-mono text-ink-muted">NIP-99</span> request with your key. Switchboard never holds it.
    </p>
  <% end %>

  <% page.with_receipt do %>
    <%= render "requests/receipt" %>
  <% end %>

  <% page.with_preview do %>
    <%= render Shared::Drawer::DrawerComponent.new(title: "Request preview", id: "request-preview-drawer") do %>
      <%= render "requests/preview", request: draft %>
    <% end %>
  <% end %>
<% end %>
