<%# URL-driven order drawer: a right-side slide-over rendered open whenever ?order_id is present, mirroring
    the service-detail drawer's chrome. The detail loads lazily in a turbo-frame (only the opened order). It
    is URL state, so refresh keeps it open and the backdrop / close / Escape navigate to close_path (which
    drops the param). Locals: order_id, title, close_path. The slide-in uses the @starting-style variant. %>
<div class="fixed inset-0 z-50 overflow-hidden" role="dialog" aria-modal="true" aria-label="<%= title %>"
	data-controller="dismiss" data-dismiss-url-value="<%= close_path %>" data-action="keydown.esc@window->dismiss#close">
	<%= link_to close_path, class: "absolute inset-0 bg-canvas/70 backdrop-blur-sm transition-opacity duration-300 ease-out starting:opacity-0", aria: { label: "Close" } do %><% end %>

	<div class="absolute inset-y-0 right-0 flex max-w-full pl-10 sm:pl-16">
		<div class="w-screen max-w-2xl transform transition-transform duration-300 ease-out starting:translate-x-full">
			<div class="flex h-full flex-col border-l border-border-strong bg-surface-2 shadow-panel">
				<div class="flex items-start justify-between gap-3 border-b border-border px-6 py-4">
					<h2 class="min-w-0 truncate font-display text-lg font-semibold tracking-tight text-ink"><%= title %></h2>
					<%= link_to close_path, class: "-m-2 shrink-0 p-2 text-ink-faint transition-colors hover:text-ink" do %>
						<span class="sr-only">Close panel</span>
						<i class="hgi-stroke hgi-cancel-01 text-xl" aria-hidden="true"></i>
					<% end %>
				</div>
				<div class="flex-1 overflow-y-auto px-6 py-6">
					<%= turbo_frame_tag order_detail_frame(order_id), src: order_path(order_id), loading: :lazy do %>
						<p class="text-sm text-ink-muted">Loading order…</p>
					<% end %>
				</div>
			</div>
		</div>
	</div>
</div>
