<%# The order detail lives in a turbo-frame so the SAME action serves the full page and the drawer's lazy
    frame (opened from the ledger / thread via ?order_id). The live subscription + actions live inside it. %>
<div class="mx-auto max-w-2xl">
	<%= turbo_frame_tag order_detail_frame(@order.id) do %>
		<%= turbo_stream_from Orders::Ui::State.strip(order: @order).stream %>
		<%= render Orders::Lifecycle::LifecycleComponent.new(order: @order) %>

		<div class="mt-4">
			<%= render Shared::Card::CardComponent.new(padding: :p5) do %>
				<%= render Orders::Details::DetailsComponent.new(order: @order) %>
				<%= render Orders::Request::RequestComponent.new(order: @order, viewer: current_user) %>
				<%= render Orders::Actions::ActionsComponent.new(order: @order, viewer: current_user) %>
			<% end %>

			<%# consumer: the provider's delivered result, decrypted client-side (renders for the consumer once funded) %>
			<%= render Orders::Result::ResultComponent.new(order: @order, viewer: current_user) %>
		</div>
	<% end %>
</div>
