<!DOCTYPE html>
<html lang="en" class="h-full bg-canvas">
  <head>
    <title><%= content_for(:title) || "Switchboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Switchboard">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# DM Sans (sans/body) + Hanken Grotesk (display) + JetBrains Mono, and Hugeicons, per the design system %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Hanken+Grotesk:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;700&display=swap">
    <link rel="stylesheet" href="https://cdn.hugeicons.com/font/hgi-stroke-rounded.css">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-canvas text-ink font-sans antialiased selection:bg-copper/20">
    <%# Mobile sidebar: a slide-over dialog toggled by the top-bar menu button (Tailwind Plus Elements). %>
    <el-dialog>
      <dialog id="mobile-sidebar" class="backdrop:bg-transparent lg:hidden">
        <el-dialog-backdrop class="fixed inset-0 bg-canvas/80 backdrop-blur-sm transition-opacity duration-300 ease-linear data-closed:opacity-0"></el-dialog-backdrop>

        <div tabindex="0" class="fixed inset-0 flex focus:outline-none">
          <el-dialog-panel class="group/dialog-panel relative mr-16 flex w-full max-w-xs flex-1 transform transition duration-300 ease-in-out data-closed:-translate-x-full">
            <div class="absolute top-0 left-full flex w-16 justify-center pt-5 duration-300 ease-in-out group-data-closed/dialog-panel:opacity-0">
              <button type="button" command="close" commandfor="mobile-sidebar" class="-m-2.5 p-2.5">
                <span class="sr-only">Close sidebar</span>
                <i class="hgi-stroke hgi-cancel-01 text-xl text-ink" aria-hidden="true"></i>
              </button>
            </div>

            <div class="relative flex grow flex-col gap-y-5 overflow-y-auto border-r border-border bg-canvas px-6 pb-4">
              <%= render Layout::Sidebar::SidebarComponent.new %>
            </div>
          </el-dialog-panel>
        </div>
      </dialog>
    </el-dialog>

    <%# Static sidebar for desktop. %>
    <div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-72 lg:flex-col">
      <div class="flex grow flex-col gap-y-5 overflow-y-auto border-r border-border bg-canvas px-6 pb-4">
        <%= render Layout::Sidebar::SidebarComponent.new %>
      </div>
    </div>

    <div class="lg:pl-72">
      <div class="sticky top-0 z-40 lg:mx-auto lg:max-w-7xl lg:px-8">
        <div class="flex h-16 items-center gap-x-4 border-b border-border bg-canvas/85 px-4 backdrop-blur sm:gap-x-6 sm:px-6 lg:px-0">
          <button type="button" command="show-modal" commandfor="mobile-sidebar" class="-m-2.5 p-2.5 text-ink-muted hover:text-ink lg:hidden">
            <span class="sr-only">Open sidebar</span>
            <i class="hgi-stroke hgi-menu-01 text-xl" aria-hidden="true"></i>
          </button>

          <%# Separator %>
          <div aria-hidden="true" class="h-6 w-px bg-border lg:hidden"></div>

          <div class="flex flex-1 items-center gap-x-4 lg:gap-x-6">
            <%# Wayfinding: breadcrumb trail, held visible by the sticky bar as the page scrolls. %>
            <%= render Layout::Breadcrumb::BreadcrumbComponent.new(crumbs: [ { label: content_for(:title) } ]) %>

            <div class="ml-auto flex items-center gap-x-3 lg:gap-x-5">
              <% if signed_in? %>
                <%# Provider studio: the "switch to selling" CTA, the one primary action up here. %>
                <%= render Shared::Button::ButtonComponent.new(variant: :primary, size: :sm, tag: :a, href: studio_path, icon: "store-add-01") do %>
                  <span class="hidden sm:inline">Provider studio</span>
                <% end %>

                <%= render Layout::NotificationsBell::NotificationsBellComponent.new(user: current_user) %>

                <%# Separator %>
                <div aria-hidden="true" class="hidden lg:block lg:h-6 lg:w-px lg:bg-border"></div>
              <% end %>

              <%# Identity: avatar + dropdown when signed in, Sign in button when signed out. %>
              <%= render Layout::IdentityMenu::IdentityMenuComponent.new(user: current_user) %>
            </div>
          </div>
        </div>
      </div>

      <main class="pt-6 pb-12">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <% if flash.any? %>
            <div class="mb-8 space-y-3">
              <% flash.each do |type, message| %>
                <%= render Shared::Alert::AlertComponent.for_flash(type, message) %>
              <% end %>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>

    <%# Re-hydrates a saved nsec signer after a hard reload; opened on demand by the signer store. %>
    <% if signed_in? %>
      <%= render Sessions::UnlockDialog::UnlockDialogComponent.new(user: current_user) %>
    <% end %>
  </body>
</html>
