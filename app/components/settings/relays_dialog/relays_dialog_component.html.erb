<el-dialog>
  <dialog id="<%= DIALOG_ID %>" class="backdrop:bg-transparent">
    <el-dialog-backdrop class="fixed inset-0 bg-canvas/75 backdrop-blur-sm transition-opacity duration-200 ease-out data-closed:opacity-0"></el-dialog-backdrop>

    <div class="fixed inset-0 grid place-items-center p-4">
      <el-dialog-panel class="w-full max-w-md transform overflow-hidden rounded-2xl border border-border-strong bg-surface-2 shadow-panel transition duration-200 ease-out data-closed:scale-95 data-closed:opacity-0">
        <div class="flex items-center gap-2.5 border-b border-border px-5 py-3.5">
          <i class="hgi-stroke hgi-share-08 text-copper" aria-hidden="true"></i>
          <span class="font-mono text-xs uppercase tracking-widest text-ink-secondary">Relays</span>
          <button type="button" command="close" commandfor="<%= DIALOG_ID %>" class="-m-1.5 ml-auto p-1.5 text-ink-faint hover:text-ink">
            <span class="sr-only">Close</span>
            <i class="hgi-stroke hgi-cancel-01" aria-hidden="true"></i>
          </button>
        </div>

        <div class="p-5">
          <ul role="list" class="space-y-2">
            <% display_relays.each do |relay| %>
              <li class="flex items-center gap-2.5 rounded-lg border border-border bg-surface px-3 py-2">
                <span class="size-1.5 shrink-0 rounded-full <%= relay_status_class(relay[:status]) %>"></span>
                <span class="font-mono text-xs text-ink-secondary"><%= relay[:host] %></span>
                <button type="button" class="-m-1.5 ml-auto p-1.5 text-ink-faint hover:text-ink" aria-label="Remove <%= relay[:host] %>">
                  <i class="hgi-stroke hgi-cancel-01 text-sm" aria-hidden="true"></i>
                </button>
              </li>
            <% end %>
          </ul>

          <div class="mt-4 flex gap-2">
            <input type="text" inputmode="url" autocomplete="off" placeholder="wss://relay.example.com" aria-label="Relay URL"
                   class="block w-full rounded-lg border border-border bg-surface px-3 py-2 font-mono text-xs text-ink placeholder:text-ink-faint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright" />
            <%= render Shared::Button::ButtonComponent.new(size: :sm) do %>Add<% end %>
          </div>

          <p class="mt-3 text-xs text-ink-faint">Preview: changes are not yet published to the network.</p>
        </div>
      </el-dialog-panel>
    </div>
  </dialog>
</el-dialog>
