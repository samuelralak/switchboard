<a href="<%= helpers.message_path(conversation.id) %>"
   <%= "aria-current=\"page\"".html_safe if selected? %>
   class="flex gap-3 rounded-xl border px-3.5 py-3 transition-colors <%= selected? ? "border-border-strong bg-surface-2" : "border-border bg-surface hover:border-border-strong hover:bg-surface-2" %>">
  <%= render Shared::Avatar::AvatarComponent.new(seed: conversation.npub, size: 38, rounded: :lg) %>
  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-2">
      <% if conversation.unread? %>
        <span class="size-1.5 shrink-0 rounded-full bg-copper" aria-hidden="true"></span>
      <% end %>
      <span class="truncate text-sm <%= conversation.unread? ? "font-semibold text-ink" : "font-medium text-ink-secondary" %>"><%= conversation.service %></span>
      <span class="ml-auto shrink-0 text-xs text-ink-faint"><%= conversation.created %></span>
    </div>
    <div class="mt-2 flex items-center gap-2">
      <%= render Shared::Chip::StateChipComponent.new(state: conversation.state) %>
      <span class="truncate text-xs text-ink-faint">from <%= conversation.name %></span>
      <span class="ml-auto shrink-0 font-mono text-xs tabular-nums text-ink-secondary">+<%= helpers.number_with_delimiter(conversation.sats) %> <span class="text-ink-faint">sat</span></span>
    </div>
  </div>
</a>
