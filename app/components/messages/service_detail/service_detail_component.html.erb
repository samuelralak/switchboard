<% if listing? %>
  <%= render Catalog::ServiceDetail::ServiceDetailComponent.new(listing: service, show_cta: false) %>
<% elsif request? %>
  <%= render Requests::RequestDetail::RequestDetailComponent.new(request: service, viewer:, show_cta: false) %>
<% else %>
  <p class="text-sm leading-relaxed text-ink-muted">
    This service isn't available locally yet, so its full detail can't be shown. The order metadata is in the thread.
  </p>
<% end %>
