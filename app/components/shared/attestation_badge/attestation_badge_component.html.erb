<%# Verified mark: a small copper shield-with-check that pops (scales + brightens) when its card is hovered. %>
<%# No chip, no visible text; meaning rides the title attr + sr-only label. Same mark on cards/details/previews. %>
<span class="inline-flex shrink-0 items-center text-copper transition group-hover:scale-110 group-hover:text-copper-bright" title="<%= label %>">
  <i class="hgi-stroke hgi-security-check text-sm" aria-hidden="true"></i>
  <span class="sr-only"><%= label %></span>
</span>
