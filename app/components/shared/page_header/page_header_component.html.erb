<%= content_tag wrapper_tag, class: wrapper_class do %>
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div class="min-w-0">
      <% if eyebrow.present? %>
        <p class="mb-2.5 text-xs font-medium uppercase tracking-widest text-copper"><%= eyebrow %></p>
      <% end %>
      <h1 class="font-display text-lg font-semibold tracking-tight text-ink"><%= title %></h1>
      <% if subtitle.present? %>
        <p class="mt-0.5 max-w-2xl text-sm leading-relaxed text-ink-muted"><%= subtitle %></p>
      <% end %>
    </div>
    <% if action? %>
      <div class="shrink-0"><%= action %></div>
    <% end %>
  </div>
<% end %>
