<el-dialog>
  <dialog id="<%= dialog_id %>" aria-labelledby="<%= dialog_id %>-title" class="fixed inset-0 size-auto max-h-none max-w-none overflow-hidden bg-transparent backdrop:bg-transparent">
    <el-dialog-backdrop class="fixed inset-0 bg-canvas/70 backdrop-blur-sm transition-opacity duration-500 ease-in-out data-closed:opacity-0"></el-dialog-backdrop>

    <div tabindex="0" class="absolute inset-0 overflow-hidden pl-10 focus:outline-none sm:pl-16">
      <el-dialog-panel class="ml-auto block size-full max-w-2xl transform transition duration-500 ease-in-out data-closed:translate-x-full sm:duration-700">
        <div class="flex h-full flex-col border-l border-border-strong bg-surface-2 shadow-panel">
          <div class="flex items-start justify-between gap-3 border-b border-border px-6 py-4">
            <h2 id="<%= dialog_id %>-title" class="min-w-0 truncate font-display text-lg font-semibold tracking-tight text-ink"><%= title %></h2>
            <button type="button" command="close" commandfor="<%= dialog_id %>" class="-m-2 shrink-0 rounded-md p-2 text-ink-faint transition-colors hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright">
              <span class="sr-only">Close panel</span>
              <i class="hgi-stroke hgi-cancel-01 text-xl" aria-hidden="true"></i>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto px-6 py-6"><%= content %></div>
        </div>
      </el-dialog-panel>
    </div>
  </dialog>
</el-dialog>
