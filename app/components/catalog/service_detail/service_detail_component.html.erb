<div class="flex flex-col gap-6">
  <%# cover image (first listing image), when present %>
  <% if listing.image.present? %>
    <img src="<%= listing.image %>" alt="<%= listing.title %>" loading="lazy"
         data-controller="image-fallback" data-action="error->image-fallback#failed"
         class="aspect-video w-full rounded-xl border border-border object-cover">
  <% end %>

  <%# mode + delivery + description + provider identity %>
  <div>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
      <% if listing.fulfillment.present? %>
        <%= render Shared::Chip::ChipComponent.new(tone: automated? ? :copper : :muted, label: automated? ? "automated" : "human") %>
      <% end %>
      <%= render Shared::AttestationBadge::AttestationBadgeComponent.new(attested: listing.attested?, focusable: true) %>
      <% if delivery_label %>
        <span class="text-xs text-ink-muted"><%= delivery_label %></span>
      <% end %>
    </div>
    <div class="markdown mt-3"><%= helpers.markdown(listing.description) %></div>
    <div class="mt-4">
      <%= render Shared::ProviderChip::ProviderChipComponent.new(name: "provider", npub: listing.provider_npub, linked: true) %>
    </div>
  </div>

  <%# Transaction terms: price + delivery on top, the escrow guarantee below. The price leads (copper),
      proportionate rather than a hero number. %>
  <%= render Shared::Card::CardComponent.new(padding: :p5) do %>
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
      <span class="flex items-baseline gap-2">
        <% if listing.price? %>
          <%= render Shared::PriceTag::PriceTagComponent.new(amount: listing.price_amount, suffix: listing.price_currency, tone: :copper) %>
          <span class="text-xs text-ink-muted"><%= price_basis_label %></span>
        <% else %>
          <span class="text-sm text-ink-muted">Price on request</span>
        <% end %>
      </span>
      <% if delivery_label %>
        <span class="text-xs text-ink-muted"><%= delivery_label %></span>
      <% end %>
    </div>

    <div class="my-4 h-px bg-border"></div>

    <div class="flex items-start gap-2">
      <%= render Shared::Icon::IconComponent.new(name: "shield-01", size: :sm, color: "text-copper", extra: "mt-0.5 shrink-0") %>
      <div>
        <p class="text-xs font-medium uppercase tracking-wider text-ink-muted">escrow on every job</p>
        <p class="mt-1 text-sm leading-relaxed text-ink-secondary"><%= escrow_explainer %></p>
      </div>
    </div>
  <% end %>

  <%# inputs this service expects (only when the listing declares a schema) %>
  <% if listing.input_schema.any? %>
    <%= render Shared::Card::CardComponent.new(padding: :p5) do %>
      <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-muted">inputs this service expects</p>
      <ul class="-mb-1 divide-y divide-border">
        <% listing.input_schema.each do |field| %>
          <li class="flex items-center justify-between gap-3 py-3">
            <span class="text-sm text-ink"><%= field[:label] %></span>
            <span class="flex shrink-0 items-center gap-3 text-xs">
              <span class="text-ink-faint"><%= field[:type] %></span>
              <span class="<%= field[:required] ? "text-copper" : "text-ink-faint" %>"><%= field[:required] ? "required" : "optional" %></span>
            </span>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%# microstandard conformance (only when the listing carries the marker) %>
  <% if listing.conforms? %>
    <p class="flex flex-wrap items-center gap-x-2.5 gap-y-1 text-xs leading-relaxed text-ink-faint">
      <span>conforms to the service-listing convention</span>
      <span class="inline-block h-2.5 w-px bg-border" aria-hidden="true"></span>
      <span class="font-mono text-ink-muted">t:<%= Catalog::Listing.marker %></span>
      <% if listing.capability.present? %>
        <span class="inline-block h-2.5 w-px bg-border" aria-hidden="true"></span>
        <span class="font-mono text-ink-muted">svc:<%= listing.capability %></span>
      <% end %>
      <span class="inline-block h-2.5 w-px bg-border" aria-hidden="true"></span>
      <span class="font-mono text-ink-muted">kind 30402</span>
    </p>
  <% end %>

  <%# buyer action (hidden when the provider views their own service in the messages drawer) %>
  <% if show_cta %>
  <div>
    <% if !hosted? %>
      <%# Posted outside Switchboard: not orderable with escrow here. The author sees the republish path; the
          rest of the world sees a disabled action with an honest reason. %>
      <% if owner? %>
        <div class="rounded-xl border border-copper-dim/40 bg-copper/5 p-4">
          <div class="flex items-start gap-2.5">
            <%= render Shared::Icon::IconComponent.new(name: "alert-02", size: :sm, color: "text-copper", extra: "mt-0.5 shrink-0") %>
            <div>
              <p class="text-sm font-medium text-ink">Not published through Switchboard</p>
              <p class="mt-1 text-sm leading-relaxed text-ink-secondary">
                This listing was posted elsewhere, so buyers can't order it with escrow here. Republish it through Provider studio to make it orderable.
              </p>
            </div>
          </div>
          <div class="mt-4">
            <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, tag: :a,
              href: helpers.new_studio_listing_path, icon: "arrow-right-01") do %>Publish in Provider studio<% end %>
          </div>
        </div>
      <% else %>
        <div class="rounded-xl border border-border bg-inset p-4">
          <div class="flex items-start gap-2.5">
            <%= render Shared::Icon::IconComponent.new(name: "alert-02", size: :sm, color: "text-ink-muted", extra: "mt-0.5 shrink-0") %>
            <p class="text-sm leading-relaxed text-ink-secondary">
              This service was posted outside Switchboard, so it can't be ordered with escrow here. Only services published through Switchboard support escrow ordering.
            </p>
          </div>
        </div>
        <div class="mt-3">
          <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, disabled: true, icon: "arrow-right-01") do %>Request this service<% end %>
        </div>
      <% end %>
    <% elsif orderable? %>
      <form action="<%= helpers.orders_path %>" method="post" class="block">
        <input type="hidden" name="authenticity_token" value="<%= helpers.form_authenticity_token %>">
        <input type="hidden" name="order[coordinate]" value="<%= order_coordinate %>">
        <input type="hidden" name="order[dedupe_key]" value="<%= SecureRandom.uuid %>">
        <% if tier2_offered? %>
          <fieldset class="mb-3 space-y-2">
            <legend class="mb-1.5 text-xs font-medium uppercase tracking-wider text-ink-faint">Escrow type</legend>
            <label class="flex cursor-pointer gap-2.5 rounded-lg border border-border p-3 has-[:checked]:border-copper-dim has-[:checked]:bg-copper/5">
              <input type="radio" name="order[tier]" value="<%= Orders::Tiers::TIER1_HTLC %>" checked class="mt-0.5 accent-copper">
              <span class="text-sm">
                <span class="font-medium text-ink">Standard escrow</span>
                <span class="mt-0.5 block text-xs leading-relaxed text-ink-muted">You release the funds when the work satisfies you, or reclaim them after the timelock. The lock is key-locked to you, never us.</span>
              </span>
            </label>
            <label class="flex cursor-pointer gap-2.5 rounded-lg border border-border p-3 has-[:checked]:border-copper-dim has-[:checked]:bg-copper/5">
              <input type="radio" name="order[tier]" value="<%= Orders::Tiers::TIER2_ARBITER %>" class="mt-0.5 accent-copper">
              <span class="text-sm">
                <span class="font-medium text-ink">Mediated escrow</span>
                <span class="mt-0.5 block text-xs leading-relaxed text-ink-muted">If the work goes wrong, a platform arbiter can co-sign the release to either side. The arbiter alone can never move or seize the funds. Lower limit, longer lock.</span>
              </span>
            </label>
          </fieldset>
        <% end %>

        <%# Escrow mint: the buyer picks from the vetted, server-validated allowlist when more than one exists. %>
        <% if single_mint? %>
          <input type="hidden" name="order[mint_url]" value="<%= default_mint %>">
        <% else %>
          <div class="mb-3">
            <label for="order_mint_url" class="mb-1.5 block text-xs font-medium uppercase tracking-wider text-ink-faint">Escrow mint</label>
            <div class="relative">
              <select id="order_mint_url" name="order[mint_url]" class="w-full appearance-none rounded-lg border border-border bg-surface py-2 pl-3 pr-9 text-sm font-medium text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright">
                <% mint_options.each do |url| %>
                  <option value="<%= url %>"><%= mint_host(url) %></option>
                <% end %>
              </select>
              <i class="hgi-stroke hgi-arrow-down-01 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-faint" aria-hidden="true"></i>
            </div>
          </div>
        <% end %>

        <%= render Orders::MintNotice::MintNoticeComponent.new(mint: (default_mint if single_mint?)) %>

        <div class="mt-4">
          <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, type: "submit", icon: "arrow-right-01") do %>Order this service<% end %>
        </div>
      </form>
    <% else %>
      <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, icon: "arrow-right-01") do %>Request this service<% end %>
    <% end %>
    <% if hosted? && request_note %>
      <p class="mt-3 text-xs leading-relaxed text-ink-muted"><%= request_note %></p>
    <% end %>
  </div>
  <% end %>
</div>
