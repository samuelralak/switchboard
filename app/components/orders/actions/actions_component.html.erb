<div class="mt-5 border-t border-border pt-5">
	<% if fund? %>
		<div data-controller="funding"
			data-funding-order-id-value="<%= order.id %>"
			data-funding-mint-value="<%= order.mint_url %>"
			data-funding-amount-value="<%= order.amount_sats %>"
			data-funding-provider-value="<%= order.provider_pubkey %>"
			data-funding-consumer-value="<%= order.consumer_pubkey %>"
			data-funding-relays-value="<%= relays_json %>"
			data-funding-locktime-seconds-value="<%= locktime_seconds %>"
			data-funding-tier-value="<%= order.tier %>"
			data-funding-arbiter-value="<%= arbiter_pubkey %>">
			<div class="flex items-start gap-2">
				<%= render Shared::Icon::IconComponent.new(name: "shield-01", size: :sm, color: "text-copper", extra: "mt-0.5 shrink-0") %>
				<p class="text-sm leading-relaxed text-ink-secondary">
					Lock <%= number_with_delimiter(order.amount_sats) %> sat over Lightning to fund the escrow.
					<% if order.tier2? %>You can escalate a dispute to the platform arbiter, who can co-sign a release to either side but can never move the funds alone.<% end %>
				</p>
			</div>

			<%= render Orders::MintNotice::MintNoticeComponent.new(mint: order.mint_url) %>

			<div class="mt-4">
				<%= render Shared::Button::ButtonComponent.new(variant: :primary, icon: "arrow-right-01",
					data: { funding_target: "start", action: "funding#start" }) do %>Fund escrow<% end %>
			</div>

			<div data-funding-target="panel" class="mt-4 hidden">
				<p data-funding-target="status" role="status" class="text-sm text-ink-secondary"></p>
				<div data-funding-target="invoice" class="mt-3 hidden">
					<p class="text-xs font-medium uppercase tracking-wider text-ink-muted">Pay this Lightning invoice</p>
					<textarea data-funding-target="bolt11" readonly rows="3"
						class="mt-1 w-full resize-none rounded-lg border border-border bg-surface p-2 font-mono text-xs text-ink-secondary"></textarea>
					<button type="button" data-action="funding#copy"
						class="mt-1 text-xs font-medium text-copper hover:text-copper-bright">Copy invoice</button>
				</div>
			</div>

			<p data-funding-target="error" role="alert" class="mt-3 hidden text-sm text-lamp-fault"></p>

			<%# tier-specific lock terms (hashlock for tier-1; arbiter_pubkey + required_signatures for tier-2) are
			    appended by the controller from the report payload, so no fixed hidden input for them here. %>
			<%= form_with url: order_funding_path(order), method: :post, data: { funding_target: "form" }, class: "hidden" do %>
				<input type="hidden" name="order[mint_url]" data-funding-target="mintUrl">
				<input type="hidden" name="order[locktime]" data-funding-target="locktime">
				<input type="hidden" name="order[lock_pubkey]" data-funding-target="lockPubkey">
				<input type="hidden" name="order[refund_pubkey]" data-funding-target="refundPubkey">
			<% end %>
		</div>
	<% elsif release? %>
		<div data-controller="settlement"
			data-settlement-order-id-value="<%= order.id %>"
			data-settlement-mint-value="<%= order.mint_url %>"
			data-settlement-relays-value="<%= relays_json %>"
			data-settlement-own-value="<%= order.consumer_pubkey %>"
			data-settlement-peer-value="<%= order.provider_pubkey %>"
			data-settlement-settle-url-value="<%= settle_order_path(order) %>"
			data-settlement-release-url-value="<%= order_release_path(order) %>"
			data-settlement-locktime-value="<%= order.lock&.locktime&.to_i %>"
			data-settlement-tier-value="<%= order.tier %>">
			<% if released? %>
				<p class="text-sm leading-relaxed text-ink-secondary">
					You released the escrow. The provider can now redeem; the order settles once they do. You can
					still refund if the lock expires before they redeem.
				</p>
				<div class="mt-4">
					<%= render Shared::Button::ButtonComponent.new(variant: :ghost,
						data: { settlement_target: "refund", action: "settlement#refund" }) do %>Refund<% end %>
				</div>
			<% else %>
				<p class="text-sm leading-relaxed text-ink-secondary">
					Release the escrow once the delivered result satisfies you, or refund after the lock expires if it never arrives.
				</p>
				<div class="mt-4 flex flex-wrap gap-2">
					<%= render Shared::Button::ButtonComponent.new(variant: :primary, icon: "square-lock-02",
						data: { settlement_target: "release", action: "settlement#release" }) do %>Release escrow<% end %>
					<%= render Shared::Button::ButtonComponent.new(variant: :ghost,
						data: { settlement_target: "refund", action: "settlement#refund" }) do %>Refund<% end %>
				</div>
			<% end %>
			<p data-settlement-target="status" role="status" class="mt-3 text-sm text-ink-secondary"></p>
			<p data-settlement-target="error" role="alert" class="mt-3 hidden text-sm text-lamp-fault"></p>
		</div>
	<% elsif settle? %>
		<%# provider: deliver the finished result to the client, sealed end to end (the runtime never sees it) %>
		<div data-controller="order-result"
			data-order-result-order-id-value="<%= order.id %>"
			data-order-result-own-value="<%= order.provider_pubkey %>"
			data-order-result-peer-value="<%= order.consumer_pubkey %>"
			data-order-result-coordinate-value="<%= order.listing_coordinate %>"
			data-order-result-relays-value="<%= dm_relays_json %>"
			data-order-result-deliver-url-value="<%= order_delivery_path(order) %>">
			<div class="mb-4 flex items-start gap-2">
				<%= render Shared::Icon::IconComponent.new(name: "sent", size: :sm, color: "text-copper", extra: "mt-0.5 shrink-0") %>
				<p class="text-sm leading-relaxed text-ink-secondary">
					Deliver the finished work, sealed to the client end to end. They review it, then release the escrow to you.
				</p>
			</div>
			<%= helpers.simple_form_for :delivery, url: "#",
				html: { data: { turbo: false, order_result_target: "form", action: "submit->order-result#send" } } do |form| %>
				<%= form.input :result, as: :text, required: true, label: "Result",
					placeholder: "The delivered work (text or markdown)",
					input_html: { rows: 4, class: "resize-y", data: { order_result_target: "field" } } %>
				<%= form.input :attachments, as: :text, required: false, label: "Attachments",
					wrapper: :switchboard_mono, hint: "One URL per line.", placeholder: "https://…",
					input_html: { rows: 2, class: "resize-y", data: { order_result_target: "attachments" } } %>
				<%= form.input :note, required: false, label: "Note",
					input_html: { data: { order_result_target: "note" } } %>
				<%= render Shared::Button::ButtonComponent.new(variant: :primary, icon: "sent", type: "submit", full: true,
					data: { order_result_target: "submit" }) do %>Submit delivery<% end %>
			<% end %>
			<p data-order-result-target="status" role="status" class="mt-3 hidden text-sm text-ink-secondary"></p>
			<p data-order-result-target="error" role="alert" class="mt-3 hidden text-sm text-lamp-fault"></p>
		</div>

		<%# provider: verify the locked budget, then redeem once the consumer releases %>
		<div class="mt-5 border-t border-border pt-5" data-controller="settlement"
			data-settlement-order-id-value="<%= order.id %>"
			data-settlement-mint-value="<%= order.mint_url %>"
			data-settlement-relays-value="<%= relays_json %>"
			data-settlement-own-value="<%= order.provider_pubkey %>"
			data-settlement-peer-value="<%= order.consumer_pubkey %>"
			data-settlement-amount-value="<%= order.amount_sats %>"
			data-settlement-hashlock-value="<%= order.lock&.hashlock %>"
			data-settlement-lock-pubkey-value="<%= order.lock&.lock_pubkey %>"
			data-settlement-locktime-value="<%= order.lock&.locktime&.to_i %>"
			data-settlement-settle-url-value="<%= settle_order_path(order) %>"
			data-settlement-tier-value="<%= order.tier %>"
			data-settlement-arbiter-pubkey-value="<%= order.lock&.arbiter_pubkey %>">
			<p class="text-sm leading-relaxed text-ink-secondary">
				<% if order.tier2? %>Verify the 2-of-3 budget, then redeem once the client releases with their co-signature (or after the arbiter rules a dispute your way).<% else %>Verify the locked budget, then redeem once the client approves and releases.<% end %>
			</p>
			<div class="mt-4 flex flex-wrap gap-2">
				<%= render Shared::Button::ButtonComponent.new(variant: :ghost, icon: "shield-01",
					data: { settlement_target: "verify", action: "settlement#verify" }) do %>Verify funds<% end %>
				<%= render Shared::Button::ButtonComponent.new(variant: :primary, icon: "arrow-right-01",
					data: { settlement_target: "redeem", action: "settlement#redeem" }) do %>Redeem<% end %>
			</div>
			<p data-settlement-target="status" role="status" class="mt-3 text-sm text-ink-secondary"></p>
			<p data-settlement-target="error" role="alert" class="mt-3 hidden text-sm text-lamp-fault"></p>
		</div>
	<% elsif redeem_after_ruling? %>
		<%# the party the arbiter ruled for completes the 2-of-3 spend with the platform's co-signature. The
		    NIP-98 call to the arbiter endpoint is authed by the LOGIN key (own); the proofs are co-signed by
		    the escrow key. %>
		<div data-controller="settlement"
			data-settlement-order-id-value="<%= order.id %>"
			data-settlement-mint-value="<%= order.mint_url %>"
			data-settlement-relays-value="<%= relays_json %>"
			data-settlement-own-value="<%= viewer.pubkey %>"
			data-settlement-peer-value="<%= viewer.pubkey == order.provider_pubkey ? order.consumer_pubkey : order.provider_pubkey %>"
			data-settlement-tier-value="<%= order.tier %>"
			data-settlement-settle-url-value="<%= settle_order_path(order) %>"
			data-settlement-arbiter-url-value="<%= arbiter_signatures_url %>">
			<div class="flex items-start gap-2">
				<%= render Shared::Icon::IconComponent.new(name: "shield-01", size: :sm, color: "text-copper", extra: "mt-0.5 shrink-0") %>
				<p class="text-sm leading-relaxed text-ink-secondary">
					The platform arbiter ruled this dispute in your favour. Claim the escrow with the arbiter's co-signature.
				</p>
			</div>
			<div class="mt-4">
				<%= render Shared::Button::ButtonComponent.new(variant: :primary, icon: "arrow-right-01",
					data: { settlement_target: "disputeRedeem", action: "settlement#disputeRedeem" }) do %>Claim with arbiter co-signature<% end %>
			</div>
			<p data-settlement-target="status" role="status" class="mt-3 text-sm text-ink-secondary"></p>
			<p data-settlement-target="error" role="alert" class="mt-3 hidden text-sm text-lamp-fault"></p>
		</div>
	<% end %>

	<%# either party can escalate a funded tier-2 order to the platform arbiter (Turbo form, no money path) %>
	<% if dispute? %>
		<div class="mt-5 border-t border-border pt-5">
			<p class="text-sm leading-relaxed text-ink-secondary">
				Work gone wrong? Escalate to the platform arbiter, who reviews the dispute and co-signs a release to the side they rule for.
			</p>
			<%= form_with url: order_dispute_path(order), method: :post, class: "mt-3 space-y-2" do %>
				<textarea name="dispute[reason]" rows="2" placeholder="What went wrong? (optional)"
					class="w-full resize-y rounded-lg border border-border bg-surface p-2 text-sm text-ink placeholder:text-ink-faint"></textarea>
				<%= render Shared::Button::ButtonComponent.new(variant: :ghost, type: "submit",
					extra: "border border-border", data: { turbo_confirm: "Open a dispute? The platform arbiter will review and rule." }) do %>Open a dispute<% end %>
			<% end %>
		</div>
	<% end %>
</div>
