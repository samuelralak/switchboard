<dl class="grid grid-cols-1 gap-x-4 gap-y-3 text-sm sm:grid-cols-2">
	<div>
		<dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">Provider</dt>
		<dd class="mt-1 truncate font-mono text-xs text-ink-secondary"><%= npub(order.provider_pubkey) %></dd>
	</div>
	<div>
		<dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">Consumer</dt>
		<dd class="mt-1 truncate font-mono text-xs text-ink-secondary"><%= npub(order.consumer_pubkey) %></dd>
	</div>
	<div>
		<dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">Mint</dt>
		<dd class="mt-1 truncate font-mono text-xs text-ink-secondary"><%= order.mint_url %></dd>
	</div>
	<% if awaiting? %>
		<div>
			<dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">Fund before</dt>
			<dd class="mt-1 text-ink-secondary"><%= order.funding_deadline_at.strftime("%b %-d, %Y · %H:%M UTC") %></dd>
		</div>
	<% end %>
</dl>
