<div id="<%= dom_id %>" class="rounded-2xl border border-border bg-surface p-6">
	<%# the escrow headline: amount + the one-glance state %>
	<div class="flex items-start justify-between gap-3">
		<div class="min-w-0">
			<div class="flex items-center gap-1.5 text-copper">
				<%= render Shared::Icon::IconComponent.new(name: "shield-01", size: :sm) %>
				<p class="text-xs font-medium uppercase tracking-wider">escrow</p>
			</div>
			<div class="mt-2">
				<%= render Shared::PriceTag::PriceTagComponent.new(amount: order.amount_sats, size: :lg, tone: :ink) %>
			</div>
		</div>
		<%= render Shared::Chip::ChipComponent.new(tone: chip_tone, label: chip_label, bordered: true) %>
	</div>

	<%# segmented progress strip %>
	<div class="mt-6 flex gap-1.5">
		<% nodes.each do |node| %>
			<span class="h-1 flex-1 rounded-full <%= strip(node.status) %>"></span>
		<% end %>
	</div>

	<%# vertical node timeline (the state machine) %>
	<ol class="mt-5">
		<% nodes.each_with_index do |node, index| %>
			<% last = index == nodes.size - 1 %>
			<li class="flex gap-3.5">
				<div class="flex flex-col items-center">
					<span class="grid size-5 shrink-0 place-items-center">
						<span class="rounded-full <%= lamp(node.status) %>"></span>
					</span>
					<% unless last %>
						<span class="my-1.5 w-px flex-1 <%= connector(node.status) %>"></span>
					<% end %>
				</div>
				<div class="min-w-0 flex-1 <%= last ? "pb-0.5" : "pb-7" %>">
					<div class="flex items-baseline gap-2.5">
						<span class="text-sm font-medium <%= label_tone(node.status) %>"><%= node.label %></span>
						<% if node.at %>
							<span class="ml-auto shrink-0 font-mono text-xs tabular-nums text-ink-faint"><%= node.at.strftime("%-d %b, %H:%M") %></span>
						<% end %>
					</div>
					<% if note?(node) %>
						<p class="mt-1.5 max-w-xl text-sm leading-relaxed text-ink-muted"><%= node.note %></p>
					<% end %>
					<% if node.countdown %>
						<p class="mt-2 inline-flex items-center gap-2 font-mono text-xs text-lamp-live">
							<span class="size-1.5 rounded-full bg-lamp-live" aria-hidden="true"></span>
							<%= node.countdown[:label] %>
							<span data-controller="countdown" data-countdown-deadline-value="<%= node.countdown[:at].to_i %>" class="tabular-nums">··:··:··</span>
							<span class="text-ink-faint">→ <%= node.countdown[:then] %></span>
						</p>
					<% end %>
				</div>
			</li>
		<% end %>
	</ol>
</div>
