<%# Consumer order row. Shares the selling row's visual language (card geometry, leading box, two-line layout,
    borderless state chip, inline mono amount) but keeps its own data: a service icon, the capability, and the
    funding countdown that is the consumer's one action. %>
<a href="<%= order_path %>" <%= "aria-current=\"page\"".html_safe if selected? %>
	class="group flex items-center gap-3 rounded-xl border px-3.5 py-3 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas <%= selected? ? "border-border-strong bg-surface-2" : "border-border bg-surface hover:border-border-strong hover:bg-surface-2" %>">
	<div class="grid size-9 shrink-0 place-items-center rounded-lg border border-border bg-inset">
		<%= render Shared::Icon::IconComponent.new(name: "package", size: :sm, color: "text-ink-faint") %>
	</div>

	<div class="min-w-0 flex-1">
		<div class="flex items-center gap-2">
			<h3 class="truncate text-sm font-medium text-ink transition-colors group-hover:text-copper"><%= row.title %></h3>
			<%# Top-right: the funding deadline is the consumer's one action, so it leads in copper while awaiting;
			    once funded the slot falls back to the order's age, mirroring the selling row's timestamp. %>
			<span class="ml-auto shrink-0 text-xs <%= awaiting? ? "font-medium text-copper" : "text-ink-faint" %>"><%= awaiting? ? "fund in #{funding_left}" : created %></span>
		</div>
		<div class="mt-2 flex items-center gap-2">
			<%= render Shared::Chip::ChipComponent.new(tone: status[:tone], label: status[:label]) %>
			<% if row.cap.present? %>
				<span class="truncate font-mono text-xs text-ink-faint"><%= row.cap %></span>
			<% end %>
			<span class="ml-auto shrink-0 font-mono text-xs tabular-nums text-ink-secondary"><%= number_with_delimiter(row.sats) %> <span class="text-ink-faint">sat</span></span>
		</div>
	</div>
</a>
