<div id="<%= dom_id %>" role="status" class="flex items-center gap-3 rounded-xl border <%= status[:band] %> px-4 py-3">
	<span class="size-2 shrink-0 rounded-full <%= status[:lamp] %>" aria-hidden="true"></span>
	<span class="text-sm font-medium <%= status[:text] %>"><%= status[:label] %></span>
</div>
