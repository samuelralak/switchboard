<% if signed_in? %>
  <el-dropdown class="relative">
    <button class="flex items-center gap-2.5 rounded-xl border border-border bg-surface py-1.5 pr-3 pl-1.5 hover:border-border-strong">
      <span class="sr-only">Open user menu</span>
      <span class="grid size-7 place-items-center rounded-lg bg-surface-2 text-copper ring-1 ring-border">
        <i class="hgi-stroke hgi-user-circle text-base" aria-hidden="true"></i>
      </span>
      <span class="hidden lg:flex lg:flex-col lg:items-start lg:gap-1.5 lg:leading-none">
        <span class="font-mono text-xs text-ink-secondary"><%= display_npub %></span>
        <span class="flex items-center gap-1 font-mono text-xs text-copper"><i class="hgi-stroke hgi-square-lock-02 text-xs" aria-hidden="true"></i>signed in</span>
      </span>
    </button>
    <el-menu anchor="bottom end" popover class="w-48 origin-top-right rounded-xl border border-border bg-surface-2 py-2 shadow-panel transition transition-discrete [--anchor-gap:--spacing(2.5)] data-closed:scale-95 data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
      <% menu_items.each do |item| %>
        <a href="<%= item[:href] %>" class="block px-3 py-1.5 text-sm/6 text-ink-secondary hover:bg-surface hover:text-ink focus:bg-surface focus:outline-hidden"><%= item[:label] %></a>
      <% end %>
      <div role="none" class="my-1.5 h-px bg-border"></div>
      <%= button_to helpers.session_path, method: :delete, class: "block w-full px-3 py-1.5 text-left text-sm/6 text-ink-secondary hover:bg-surface hover:text-ink" do %>
        Disconnect signer
      <% end %>
    </el-menu>
  </el-dropdown>
<% else %>
  <div data-controller="nostr-auth"
       data-nostr-auth-challenge-url-value="<%= helpers.session_challenge_path %>"
       data-nostr-auth-session-url-value="<%= helpers.session_path %>"
       data-nostr-auth-verify-url-value="<%= "#{Rails.application.config.x.canonical_origin}#{helpers.session_path}" %>">
    <button type="button"
            command="show-modal" commandfor="<%= Sessions::SigninDialog::SigninDialogComponent::DIALOG_ID %>"
            data-action="nostr-auth#prepare"
            class="flex items-center gap-2 rounded-xl border border-border bg-surface px-3 py-1.5 text-sm font-medium text-ink hover:border-border-strong">
      <i class="hgi-stroke hgi-square-lock-02 text-base text-copper" aria-hidden="true"></i>
      Sign in
    </button>
    <%= render Sessions::SigninDialog::SigninDialogComponent.new %>
  </div>
<% end %>
