<% if signed_in? %>
  <el-dropdown class="relative">
    <button class="flex items-center gap-1.5 rounded-xl p-0.5 hover:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright">
      <span class="sr-only">Open user menu</span>
      <% if picture %>
        <img src="<%= picture %>" alt="" data-identity-avatar
             data-controller="image-fallback" data-action="error->image-fallback#failed"
             class="size-8 rounded-lg object-cover ring-1 ring-border" />
        <%# a dead avatar URL falls back to the identicon %>
        <span data-image-fallback-placeholder class="hidden"><%= identicon_tag(pubkey, size: 32, html_class: "size-8 rounded-lg bg-surface-2 ring-1 ring-border") %></span>
      <% else %>
        <%= identicon_tag(pubkey, size: 32, html_class: "size-8 rounded-lg bg-surface-2 ring-1 ring-border") %>
      <% end %>
      <i class="hgi-stroke hgi-arrow-down-01 text-sm text-ink-faint" aria-hidden="true"></i>
    </button>
    <el-menu anchor="bottom end" popover class="w-56 origin-top-right rounded-xl border border-border bg-surface-2 py-2 shadow-panel transition transition-discrete [--anchor-gap:--spacing(2.5)] data-closed:scale-95 data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
      <div class="px-3 py-2">
        <p class="truncate text-sm font-medium text-ink" data-identity-name><%= display_label %></p>
        <% if nip05 %><p class="truncate font-mono text-xs text-ink-secondary"><%= nip05 %></p><% end %>
        <p class="font-mono text-xs text-ink-faint"><%= display_npub %></p>
      </div>
      <div role="none" class="my-1.5 h-px bg-border"></div>
      <% menu_items.each do |item| %>
        <a href="<%= item[:href] %>" class="block px-3 py-1.5 text-sm/6 text-ink-secondary hover:bg-surface hover:text-ink focus-visible:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-copper-bright"><%= item[:label] %></a>
      <% end %>
      <% if operator? %>
        <div role="none" class="my-1.5 h-px bg-border"></div>
        <a href="<%= admin_path %>" class="flex items-center gap-2 px-3 py-1.5 text-sm/6 text-ink-secondary hover:bg-surface hover:text-ink focus-visible:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-copper-bright">
          <i class="hgi-stroke hgi-dashboard-square-02 text-base text-ink-faint" aria-hidden="true"></i>
          Admin
        </a>
      <% end %>
      <div role="none" class="my-1.5 h-px bg-border"></div>
      <%= button_to helpers.session_path, method: :delete,
            form: { data: { controller: "signer-session", action: "submit->signer-session#forget" } },
            class: "block w-full px-3 py-1.5 text-left text-sm/6 text-ink-secondary hover:bg-surface hover:text-ink focus-visible:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-copper-bright" do %>
        Disconnect signer
      <% end %>
    </el-menu>
  </el-dropdown>
<% else %>
  <div data-controller="nostr-auth"
       data-nostr-auth-challenge-url-value="<%= helpers.session_challenge_path %>"
       data-nostr-auth-session-url-value="<%= helpers.session_path %>"
       data-nostr-auth-verify-url-value="<%= "#{Rails.application.config.x.canonical_origin}#{helpers.session_path}" %>">
    <button type="button"
            command="show-modal" commandfor="<%= Sessions::SigninDialog::SigninDialogComponent::DIALOG_ID %>"
            data-action="nostr-auth#prepare"
            class="flex items-center gap-2 rounded-xl border border-border bg-surface px-3 py-1.5 text-sm font-medium text-ink hover:border-border-strong">
      <i class="hgi-stroke hgi-square-lock-02 text-base text-copper" aria-hidden="true"></i>
      Sign in
    </button>
    <%= render Sessions::SigninDialog::SigninDialogComponent.new %>
  </div>
<% end %>
