<div class="flex h-16 shrink-0 items-center gap-3">
  <span class="grid size-9 place-items-center rounded-xl border border-border bg-surface text-copper">
    <i class="hgi-stroke hgi-radar-01 text-lg" aria-hidden="true"></i>
  </span>
  <span class="flex flex-col gap-1 leading-none">
    <span class="text-base font-semibold tracking-tight text-ink">Switchboard</span>
    <span class="text-xs text-ink-faint">money in, data out</span>
  </span>
</div>

<nav class="flex flex-1 flex-col">
  <ul role="list" class="flex flex-1 flex-col gap-y-7">
    <li>
      <ul role="list" class="-mx-2 space-y-1">
        <% nav_items.each do |item| %>
          <li>
            <a href="<%= item[:href] %>"<%= " aria-current=\"page\"".html_safe if item[:active] %> class="group flex items-center gap-x-3 rounded-md p-2 text-sm/6 font-semibold <%= item[:active] ? "bg-surface text-copper" : "text-ink-muted hover:bg-surface hover:text-ink" %>">
              <i class="hgi-stroke <%= item[:icon] %> shrink-0 text-lg <%= item[:active] ? "text-copper" : "text-ink-faint group-hover:text-ink" %>" aria-hidden="true"></i>
              <%= item[:label] %>
            </a>
          </li>
        <% end %>
      </ul>
    </li>

    <li>
      <div class="flex items-center justify-between px-2">
        <p class="text-xs font-medium uppercase tracking-widest text-ink-faint">relays</p>
        <a href="<%= helpers.settings_relays_path %>" class="text-xs font-medium text-copper hover:text-copper-bright">Manage</a>
      </div>
      <ul role="list" class="-mx-2 mt-2 space-y-1">
        <% sidebar_relays.each do |relay| %>
          <li>
            <span class="flex items-center gap-x-3 rounded-md p-2 text-ink-muted">
              <span class="grid size-6 shrink-0 place-items-center rounded-lg border border-border bg-surface">
                <span class="size-1.5 rounded-full <%= relay_status_class(relay[:status]) %>"></span>
              </span>
              <span class="truncate font-mono text-xs"><%= relay[:host] %></span>
            </span>
          </li>
        <% end %>
        <% if more_relays_count.positive? %>
          <li>
            <a href="<%= helpers.settings_relays_path %>" class="group flex w-full items-center gap-x-3 rounded-md p-2 text-ink-faint hover:bg-surface hover:text-ink">
              <span class="grid size-6 shrink-0 place-items-center rounded-lg border border-dashed border-border font-mono text-xs">+<%= more_relays_count %></span>
              <span class="text-sm/6">More relays</span>
            </a>
          </li>
        <% end %>
      </ul>
    </li>

    <li class="mt-auto -mx-2">
      <ul role="list" class="space-y-0.5 border-t border-border pt-3">
        <% footer_links.each do |link| %>
          <li>
            <a href="<%= link[:href] %>"<%= ' target="_blank" rel="noopener noreferrer"'.html_safe if link[:external] %>
               class="group flex items-center gap-x-3 rounded-md p-2 text-xs font-medium text-ink-faint hover:bg-surface hover:text-ink">
              <% if link[:accent] %>
                <%# Donate: a filled heart in the warm error/red tone, so support stands apart from the muted utility links. %>
                <svg viewBox="0 0 24 24" fill="currentColor" class="size-4 shrink-0 text-lamp-fault" aria-hidden="true">
                  <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.001-.001z" />
                </svg>
              <% else %>
                <i class="hgi-stroke <%= link[:icon] %> shrink-0 text-base text-ink-faint group-hover:text-ink" aria-hidden="true"></i>
              <% end %>
              <%= link[:label] %>
            </a>
          </li>
        <% end %>
      </ul>
    </li>
  </ul>
</nav>
