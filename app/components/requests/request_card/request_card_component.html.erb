<%# A list card for an open request: a constant 64px thumbnail slot (cover or a neutral placeholder) keeps %>
<%# rows aligned, matching the catalog card; the whole row is the trigger for its drawer (see requests/index). %>
<button type="button"
        id="<%= dom_id %>"
        command="show-modal" commandfor="request-drawer-<%= dom_id %>"
        data-catalog-target="card"
        data-type="request"
        data-search="<%= search_text %>"
        data-mode="manual"
        data-attested="<%= request.attested? %>"
        data-price="<%= budget_value %>"
        data-created="<%= created_at %>"
        class="group relative flex w-full items-start gap-4 rounded-2xl border bg-surface p-4 text-left transition-colors hover:bg-surface-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-copper-bright focus-visible:ring-offset-2 focus-visible:ring-offset-canvas <%= request.attested? ? "border-border-strong hover:border-copper-dim" : "border-border hover:border-border-strong" %>">
  <% if request.attested? %>
    <%# Verified: a quiet copper spine on the leading edge (reuses the nav-rail "canonical one" gesture). %>
    <span class="pointer-events-none absolute inset-y-3 left-0 w-0.5 rounded-r-full bg-copper-dim transition-colors group-hover:bg-copper">
      <span class="sr-only">Posted on Switchboard</span>
    </span>
  <% end %>
  <% if image.present? %>
    <img src="<%= image %>" alt="" loading="lazy"
         data-controller="image-fallback" data-action="error->image-fallback#failed"
         class="size-16 shrink-0 rounded-lg border border-border object-cover">
  <% end %>
  <%# revealed in place of a broken (or absent) cover image %>
  <div data-image-fallback-placeholder class="<%= "hidden " if image.present? %>grid size-16 shrink-0 place-items-center rounded-lg border border-border bg-inset">
    <%= render Shared::Icon::IconComponent.new(name: "sent", color: "text-ink-faint") %>
  </div>

  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-2.5">
      <h3 class="truncate font-display font-medium leading-snug tracking-tight text-ink transition-colors group-hover:text-copper"><%= title %></h3>
      <span class="shrink-0"><%= render Shared::Chip::ChipComponent.new(tone: :live, label: "open") %></span>
    </div>
    <div class="mt-1 flex flex-wrap items-center gap-x-2.5 gap-y-0.5 text-xs">
      <% if capability.present? %><span class="font-mono text-ink-faint"><%= capability %></span><% end %>
      <%= render Shared::ProviderChip::ProviderChipComponent.new(name: "posted by", npub: poster_npub, size: 16) %>
    </div>
    <% if blurb.present? %>
      <p class="mt-1.5 line-clamp-1 text-sm leading-relaxed text-ink-muted"><%= helpers.markdown_to_text(blurb) %></p>
    <% end %>
  </div>

  <% if budget? %>
    <div class="flex shrink-0 flex-col items-end gap-1 pt-0.5">
      <%= render Shared::PriceTag::PriceTagComponent.new(amount: budget_amount, suffix: budget_currency) %>
      <% if claim_window.present? %>
        <span class="font-mono text-xs text-ink-faint">claim in <%= claim_window %></span>
      <% end %>
    </div>
  <% end %>
</button>
