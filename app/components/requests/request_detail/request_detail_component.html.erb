<div class="flex flex-col gap-6">
  <%# cover image (first request image), when present %>
  <% if request.image.present? %>
    <img src="<%= request.image %>" alt="<%= request.title %>" loading="lazy"
         data-controller="image-fallback" data-action="error->image-fallback#failed"
         class="aspect-video w-full rounded-xl border border-border object-cover">
  <% end %>

  <%# open status + capability + the need + the poster %>
  <div>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
      <%= render Shared::Chip::ChipComponent.new(tone: :live, label: "open request") %>
      <%= render Shared::AttestationBadge::AttestationBadgeComponent.new(attested: request.attested?, label: "Posted on Switchboard", focusable: true) %>
      <% if request.capability.present? %>
        <span class="font-mono text-xs text-ink-faint"><%= request.capability %></span>
      <% end %>
    </div>
    <div class="markdown mt-3"><%= helpers.markdown(request.description) %></div>
    <div class="mt-4">
      <%= render Shared::ProviderChip::ProviderChipComponent.new(name: "posted by", npub: request.poster_npub, linked: true) %>
    </div>
  </div>

  <%# Terms: the funded budget + windows on top, the funded-bounty/escrow model below. The budget leads
      (copper), proportionate rather than a hero number. %>
  <%= render Shared::Card::CardComponent.new(padding: :p5) do %>
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
      <span class="flex items-baseline gap-2">
        <% if request.budget? %>
          <%= render Shared::PriceTag::PriceTagComponent.new(amount: request.budget_amount, suffix: request.budget_currency, tone: :copper) %>
          <span class="text-xs text-ink-muted">budget</span>
        <% else %>
          <span class="text-sm text-ink-muted">No budget set</span>
        <% end %>
      </span>
      <span class="flex flex-col items-end gap-0.5 text-xs text-ink-muted">
        <% if claim_label %><span><%= claim_label %></span><% end %>
        <% if delivery_label %><span><%= delivery_label %></span><% end %>
      </span>
    </div>

    <div class="my-4 h-px bg-border"></div>

    <div class="flex items-start gap-2">
      <%= render Shared::Icon::IconComponent.new(name: "shield-01", size: :sm, color: "text-copper", extra: "mt-0.5 shrink-0") %>
      <div>
        <p class="flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-ink-muted">
          funded bounty escrow
          <% if mediated_escrow? %>
            <span class="rounded-full bg-copper/10 px-2 py-0.5 text-xs font-medium normal-case tracking-normal text-copper"><%= escrow_label %></span>
          <% end %>
        </p>
        <p class="mt-1 text-sm leading-relaxed text-ink-secondary"><%= funding_explainer %></p>
        <% if arbiter_note %>
          <p class="mt-2 text-sm leading-relaxed text-ink-secondary"><%= arbiter_note %></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Claim action (provider side): places a request_claim order AND publishes the claimer's escrow key
      (escrow ensured at claim time) so the poster can lock the budget to them. Hidden in the messages
      drawer, where the provider has already claimed. %>
  <% if show_cta %>
  <div>
    <% if claimable? %>
      <div data-controller="claim"
        data-claim-pubkey-value="<%= viewer.pubkey %>"
        data-claim-relays-value="<%= NostrClient.configuration.relays.to_json %>"
        data-claim-mint-value="<%= Orders::Policy.default_mint %>">
        <form action="<%= helpers.orders_path %>" method="post" class="hidden" data-claim-target="form">
          <input type="hidden" name="authenticity_token" value="<%= helpers.form_authenticity_token %>">
          <input type="hidden" name="order[coordinate]" value="<%= claim_coordinate %>">
          <input type="hidden" name="order[mint_url]" value="<%= Orders::Policy.default_mint %>">
          <input type="hidden" name="order[dedupe_key]" value="<%= SecureRandom.uuid %>">
        </form>
        <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, icon: "user-multiple",
          data: { claim_target: "button", action: "claim#claim" }) do %>Claim this request<% end %>
        <p data-claim-target="error" role="alert" class="mt-3 hidden text-sm text-lamp-fault"></p>
        <p class="mt-3 text-xs leading-relaxed text-ink-muted">
          Claiming places the order and enables escrow on your account. The poster then locks the budget to you.
        </p>
      </div>
    <% else %>
      <%= render Shared::Button::ButtonComponent.new(variant: :primary, full: true, icon: "user-multiple", disabled: true) do %>Claim this request<% end %>
      <p class="mt-3 text-xs leading-relaxed text-ink-muted">
        Claiming binds the escrowed budget to you and starts the delivery clock. Open, whole-sat requests are claimable.
      </p>
    <% end %>
  </div>
  <% end %>
</div>
